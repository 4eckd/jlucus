#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

# Validate commit message format (conventional commits)
commit_msg_file=$1
commit_msg=$(cat "$commit_msg_file")

# Pattern for conventional commits
# Types: feat, fix, docs, style, refactor, perf, test, chore
pattern="^(feat|fix|docs|style|refactor|perf|test|chore|build|ci|revert)(\(.+\))?: .{3,}"

if ! echo "$commit_msg" | grep -qE "$pattern"; then
  echo "❌ Invalid commit message format!"
  echo ""
  echo "Commit messages must follow Conventional Commits format:"
  echo "  <type>(<scope>): <description>"
  echo ""
  echo "Examples:"
  echo "  feat(hero): add typing animation"
  echo "  fix(grid): resolve canvas rendering on mobile"
  echo "  docs(readme): update installation instructions"
  echo ""
  echo "Valid types: feat, fix, docs, style, refactor, perf, test, chore"
  exit 1
fi
