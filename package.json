{
  "name": "jlucus2",
  "version": "1.1.1",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:clean": "npm run clean && npm run build",
    "start": "next start",
    "lint": "eslint src/ --ext .ts,.tsx,.js,.jsx",
    "lint:fix": "eslint src/ --ext .ts,.tsx,.js,.jsx --fix",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,css,md}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,json,css,md}\"",
    "type-check": "tsc --noEmit",
    "clean": "npx rimraf .next out node_modules/.cache",
    "clean:all": "npx rimraf .next out node_modules",
    "prepare": "husky",
    "postinstall": "echo 'Dependencies installed successfully! Run npm run dev to start development.'"
  },
  "keywords": [
    "portfolio",
    "nextjs",
    "typescript",
    "tailwind",
    "terminal-ui",
    "neon",
    "developer-portfolio"
  ],
  "author": "jlucus",
  "license": "MIT",
  "description": "A Terminal Neon themed developer portfolio built with Next.js, TypeScript, and Tailwind CSS",
  "repository": {
    "type": "git",
    "url": "https://github.com/4eckd/jlucus2.git"
  },
  "bugs": {
    "url": "https://github.com/4eckd/jlucus2/issues"
  },
  "homepage": "https://jlucus.dev",
  "dependencies": {
    "@headlessui/react": "^2.2.9",
    "@heroicons/react": "^2.2.0",
    "@radix-ui/react-slot": "^1.2.4",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/node": "^25.0.3",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.23",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.23.26",
    "lucide-react": "^0.562.0",
    "next": "^16.1.0",
    "next-themes": "^0.4.6",
    "postcss": "^8.5.6",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.1.5",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "eslint": "^9.13.0",
    "eslint-config-next": "^16.1.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "lint-staged": "^15.2.11",
    "prettier": "^3.4.2",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "rimraf": "^6.1.2"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  }
}
